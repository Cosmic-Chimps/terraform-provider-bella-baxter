terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# ────────────────────────────────────────────────
# SSH Key Pair (generated by Terraform)
# ────────────────────────────────────────────────
resource "tls_private_key" "dokploy" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "dokploy" {
  key_name   = "${var.project_name}-key"
  public_key = tls_private_key.dokploy.public_key_openssh
}

resource "local_sensitive_file" "private_key" {
  content         = tls_private_key.dokploy.private_key_pem
  filename        = "${path.module}/dokploy.pem"
  file_permission = "0600"
}

# ────────────────────────────────────────────────
# VPC & Networking
# ────────────────────────────────────────────────
resource "aws_vpc" "dokploy" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name    = "${var.project_name}-vpc"
    Project = var.project_name
  }
}

resource "aws_internet_gateway" "dokploy" {
  vpc_id = aws_vpc.dokploy.id

  tags = {
    Name    = "${var.project_name}-igw"
    Project = var.project_name
  }
}

resource "aws_subnet" "public" {
  vpc_id                  = aws_vpc.dokploy.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = "${var.aws_region}a"
  map_public_ip_on_launch = true

  tags = {
    Name    = "${var.project_name}-public-subnet"
    Project = var.project_name
  }
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.dokploy.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.dokploy.id
  }

  tags = {
    Name    = "${var.project_name}-public-rt"
    Project = var.project_name
  }
}

resource "aws_route_table_association" "public" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

# ────────────────────────────────────────────────
# Security Group
# ────────────────────────────────────────────────
resource "aws_security_group" "dokploy" {
  name        = "${var.project_name}-sg"
  description = "Dokploy server security group"
  vpc_id      = aws_vpc.dokploy.id

  # SSH
  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = var.allowed_ssh_cidr
  }

  # Dokploy UI
  ingress {
    description = "Dokploy Web UI"
    from_port   = 3000
    to_port     = 3000
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # HTTP
  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # HTTPS
  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # All outbound
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name    = "${var.project_name}-sg"
    Project = var.project_name
  }
}

# ────────────────────────────────────────────────
# AMI — Latest Ubuntu 22.04 LTS
# ────────────────────────────────────────────────
data "aws_ami" "ubuntu" {
  most_recent = true
  owners      = ["099720109477"] # Canonical

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# ────────────────────────────────────────────────
# EC2 Instance
# ────────────────────────────────────────────────
resource "aws_instance" "dokploy" {
  ami                    = data.aws_ami.ubuntu.id
  instance_type          = var.instance_type
  key_name               = aws_key_pair.dokploy.key_name
  subnet_id              = aws_subnet.public.id
  vpc_security_group_ids = [aws_security_group.dokploy.id]

  root_block_device {
    volume_type           = "gp3"
    volume_size           = var.root_volume_size_gb
    delete_on_termination = true
    encrypted             = true
  }

  user_data = templatefile("${path.module}/user_data.sh.tpl", {
    dokploy_admin_email    = var.dokploy_admin_email
    dokploy_admin_password = var.dokploy_admin_password
  })

  tags = {
    Name    = "${var.project_name}-server"
    Project = var.project_name
  }
}

# ────────────────────────────────────────────────
# Elastic IP
# ────────────────────────────────────────────────
resource "aws_eip" "dokploy" {
  instance = aws_instance.dokploy.id
  domain   = "vpc"

  tags = {
    Name    = "${var.project_name}-eip"
    Project = var.project_name
  }
}

# ────────────────────────────────────────────────
# Wait for Dokploy to be ready, then register apps
# ────────────────────────────────────────────────
resource "null_resource" "wait_and_configure" {
  depends_on = [aws_eip.dokploy]

  triggers = {
    instance_id = aws_instance.dokploy.id
    repos       = join(",", [for app in var.docker_compose_apps : app.repo_url])
  }

  connection {
    type        = "ssh"
    host        = aws_eip.dokploy.public_ip
    user        = "ubuntu"
    private_key = tls_private_key.dokploy.private_key_pem
    timeout     = "10m"
  }

  provisioner "file" {
    content     = templatefile("${path.module}/configure_dokploy.sh.tpl", {
      dokploy_admin_email    = var.dokploy_admin_email
      dokploy_admin_password = var.dokploy_admin_password
      github_token           = var.github_token
      docker_compose_apps    = var.docker_compose_apps
    })
    destination = "/home/ubuntu/configure_dokploy.sh"
  }

  provisioner "remote-exec" {
    inline = [
      "chmod +x /home/ubuntu/configure_dokploy.sh",
      "/home/ubuntu/configure_dokploy.sh 2>&1 | tee /home/ubuntu/configure_dokploy.log",
    ]
  }
}
